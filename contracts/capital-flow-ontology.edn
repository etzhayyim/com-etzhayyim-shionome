;; capital-flow-ontology.kotoba.edn
;; 潮目 (shionome) — cross-asset capital-flow observatory ontology (ADR-2606072200)
;;
;; Ingests PUBLIC market data across asset classes (equities / govt-bonds / credit /
;; commodities / FX / crypto / real-estate / cash) and weaves OBSERVED CAPITAL ROTATION —
;; どこからどこへ資金が流れているか — into ONE kotoba Datom flow-graph + dry-run social posts.
;; The distinctive object is the FLOW GRAPH between CAPITAL BUCKETS (asset-class / sector /
;; region / theme): which bucket money is entering, which it is leaving, and the rotation
;; pairs between them — aggregate-first and edge-primary. An observational MIRROR of where
;; money is moving, never a trade signal, never a recommendation, never a price target.
;;
;; STOCK LAYER (ADR-2606072200 R1) — alongside the FLOW graph, a bucket may carry an
;; :outstanding-usd snapshot: the observed total SIZE (stock) of an asset class, in USD
;; trillions. Read-side `stock_pyramid` aggregates the latest such snapshot per asset class
;; into the "how big is everything" sizing view (the Visual Capitalist money-and-markets
;; pyramid: physical currency < broad money < equities < debt < real estate < derivatives
;; notional, with gold / crypto sized against them). This is a FACTUAL observed quantity,
;; exactly like :return-pct / :yield-pct — NOT a per-bucket rating/signal/target (G2/G4
;; untouched): a size is descriptive, never a trade instruction (トレードはしない).
;;
;; THE DEFINING INVARIANT — トレードはしない (G2 no-trade / non-advisory): shionome NEVER
;; emits a buy/sell signal, a price target, an over/under-weight call, or any portfolio
;; instruction. The :flow/kind vocab is purely FACTUAL/observational; advisory + trade tokens
;; are UNREPRESENTABLE (not enum members), and every output carries :no-trade-notice = true.
;;
;; Siblings (no overlap): mitooshi (probabilistic FORECASTS, distribution-only — shionome
;; observes REALIZED flows, never forecasts), kanjo (company financial DISCLOSURE KG),
;; kanae (government FISCAL flow render), watari (live ship/aircraft positions), kabuto
;; (supply-chain KG), keizu (government power-relations). shionome is the CROSS-ASSET
;; capital-rotation observatory.
;;
;; STRUCTURAL INVARIANTS live in THREE places each (this schema :db/allowed / enum +
;; lexicon :const / :enum + Python ValueError). The closed vocab vectors below are the
;; single source the structural-invariant test (src/shionome/methods/test_charter_invariants.cljc) parses.

{:ontology/id        "com.etzhayyim.shionome.capital-flow"
 :ontology/version   1
 :ontology/title     "潮目 (shionome) — cross-asset capital-flow observatory"
 :ontology/adr       "2606072200"

 ;; ── closed structural vocab (the invariants, as data) ───────────────────────
 ;; G1 — a node is a public CAPITAL BUCKET (an asset class / sector / region / theme),
 ;;      never a person / private account / portfolio / trader. :individual / :account /
 ;;      :portfolio / :person ABSENT (no tracking of individual investors; no-doxxing).
 :ontology/bucket-scopes    [:asset-class :sector :region :theme]
 ;; G2 — flow kinds are FACTUAL OBSERVATIONS of capital movement. NO trade/advisory token
 ;;      (:buy / :sell / :long / :short / :recommend / :overweight / :target-price ABSENT —
 ;;      a trade instruction is unrepresentable; トレードはしない).
 :ontology/flow-kinds       [:rotation :fund-inflow :fund-outflow :price-move
                             :cross-correlation :volume-shift :yield-shift :fx-flow]
 ;; G2 — snapshot metrics are FACTUAL observed quantities (return / net-flow / volume / yield /
 ;;      spread / drawdown / outstanding-usd). :outstanding-usd = the observed total SIZE (stock)
 ;;      of a bucket in USD trillions — the money-pyramid layer; a size, never a signal/target.
 :ontology/snapshot-metrics [:return-pct :net-fund-flow :volume-z :yield-pct :spread-bps :drawdown-pct :outstanding-usd]
 ;; A FACTUAL cross-asset regime descriptor (descriptive, NOT advice — carries the no-trade
 ;; notice). :buy-the-dip / :rotate-into / any imperative ABSENT.
 :ontology/regimes          [:risk-on :risk-off :mixed :indeterminate]
 ;; G11 — every datom declares its sourcing honesty.
 :ontology/sourcing-grades  [:representative :authoritative]
 ;; G8 — at R0 a social post is dry-run ONLY. :published ABSENT (outward-gated; published
 ;;      requires Council Lv6+ + operator + member signature).
 :ontology/post-statuses    [:dry-run]

 :schema
 [;; ── :bucket/* — a public CAPITAL BUCKET (G1: never a person/account) ─────────
  {:db/ident :bucket/id          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
  {:db/ident :bucket/scope       :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:asset-class :sector :region :theme]
   :db/doc "G1 — :individual / :account / :portfolio / :person / :trader are UNREPRESENTABLE. A node is a public capital bucket, not an investor (observational mirror, never a target/recommendation)."}
  {:db/ident :bucket/label       :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
  {:db/ident :bucket/asset-class :db/valueType :db.type/string  :db/cardinality :db.cardinality/one
   :db/doc "the parent asset class (equities / govt-bonds / credit / commodities / fx / crypto / real-estate / cash)."}
  {:db/ident :bucket/region      :db/valueType :db.type/string  :db/cardinality :db.cardinality/one
   :db/doc "ISO-3166 / supranational region code (us / jp / eu / cn / em / dm / global)."}
  {:db/ident :bucket/risk        :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:risk :safe :neutral]
   :db/doc "FACTUAL risk-bucket tag used by the regime descriptor (risk asset vs safe haven). Descriptive, not advice."}
  {:db/ident :bucket/sourcing    :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:representative :authoritative]}
  {:db/ident :bucket/sources     :db/valueType :db.type/string  :db/cardinality :db.cardinality/many
   :db/doc "G3 — ≥1 public-source URL/CID for the bucket definition; flows need ≥2."}
  ;; NOTE: there is deliberately NO :bucket/rating / :bucket/signal / :bucket/target / :bucket/score.
  ;; G2/G4 — concentration is computed on READ from incident flows, never stored per-bucket;
  ;; a rating/signal/target is a trade instruction and is UNREPRESENTABLE (トレードはしない).

  ;; ── :flow/* — an OBSERVED capital movement between buckets (edge-primary, G2/G4) ──
  {:db/ident :flow/id            :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
  {:db/ident :flow/source        :db/valueType :db.type/ref     :db/cardinality :db.cardinality/one :db/doc "→ :bucket/id (where capital is leaving from; 'external' for a pure inflow)"}
  {:db/ident :flow/target        :db/valueType :db.type/ref     :db/cardinality :db.cardinality/one :db/doc "→ :bucket/id (where capital is going to; 'external' for a pure outflow)"}
  {:db/ident :flow/kind          :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:rotation :fund-inflow :fund-outflow :price-move
                :cross-correlation :volume-shift :yield-shift :fx-flow]
   :db/doc "G2 — FACTUAL observation kinds ONLY. :buy / :sell / :long / :short / :recommend / :overweight / :target-price are UNREPRESENTABLE (トレードはしない)."}
  {:db/ident :flow/magnitude     :db/valueType :db.type/double  :db/cardinality :db.cardinality/one
   :db/doc "observed flow magnitude in :flow/unit (e.g. USD bn of net fund flow, or |Δ| of relative return). Non-negative."}
  {:db/ident :flow/unit          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one
   :db/doc "the unit of magnitude (usd-bn / pct / bps / zscore)."}
  {:db/ident :flow/no-trade-notice :db/valueType :db.type/boolean :db/cardinality :db.cardinality/one
   :db/doc "G2 INVARIANT — only true. A flow is an observation, never a trade instruction."}
  {:db/ident :flow/as-of         :db/valueType :db.type/long    :db/cardinality :db.cardinality/one
   :db/doc "G10 — observed-at; append-only. A new observation is a NEW datom, never an overwrite (非終末論)."}
  {:db/ident :flow/sourcing      :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:representative :authoritative]}
  {:db/ident :flow/sources       :db/valueType :db.type/string  :db/cardinality :db.cardinality/many
   :db/doc "G3 — ≥2 public-source URLs/CIDs (exchange data / fund-flow report / central-bank release / index provider)."}

  ;; ── :snap/* — an observed AS-OF state of a bucket (append-only, G10) ─────────
  {:db/ident :snap/id            :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
  {:db/ident :snap/bucket        :db/valueType :db.type/ref     :db/cardinality :db.cardinality/one :db/doc "→ :bucket/id"}
  {:db/ident :snap/metric        :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:return-pct :net-fund-flow :volume-z :yield-pct :spread-bps :drawdown-pct :outstanding-usd]
   :db/doc ":outstanding-usd = observed total SIZE (stock) of the bucket in USD trillions (the money-pyramid layer). FACTUAL, like the other metrics — NOT a rating/signal/target (G2/G4); summed only with other :outstanding-usd values, never with flow magnitudes (different unit)."}
  {:db/ident :snap/value         :db/valueType :db.type/double  :db/cardinality :db.cardinality/one}
  {:db/ident :snap/as-of         :db/valueType :db.type/long    :db/cardinality :db.cardinality/one}
  {:db/ident :snap/sourcing      :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:representative :authoritative]}
  {:db/ident :snap/sources       :db/valueType :db.type/string  :db/cardinality :db.cardinality/many}

  ;; ── :post/* — a DRY-RUN social post narrating an AGGREGATE flow finding ──────
  {:db/ident :post/id            :db/valueType :db.type/string  :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
  {:db/ident :post/subject       :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
  {:db/ident :post/body          :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
  {:db/ident :post/status        :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one
   :db/allowed [:dry-run]
   :db/doc "G8 — :published ABSENT; live posting needs Council Lv6+ + operator + member signature."}
  {:db/ident :post/is-mirror     :db/valueType :db.type/boolean :db/cardinality :db.cardinality/one :db/doc "G5 — only true."}
  {:db/ident :post/no-trade-notice :db/valueType :db.type/boolean :db/cardinality :db.cardinality/one :db/doc "G2 — only true."}
  {:db/ident :post/server-held-key :db/valueType :db.type/boolean :db/cardinality :db.cardinality/one :db/doc "G7 — only false; the member signs (ADR-2605231525)."}
  {:db/ident :post/author        :db/valueType :db.type/string  :db/cardinality :db.cardinality/one}
  {:db/ident :post/sources       :db/valueType :db.type/string  :db/cardinality :db.cardinality/many}]}
